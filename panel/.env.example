# Copy to .env and fill in values before running docker compose up.

# ── Database ───────────────────────────────────────────────────────────────────
# Used directly for local dev. Docker overrides this with the service hostname.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/traceback

# ── Redis ──────────────────────────────────────────────────────────────────────
# Same override applies for Docker.
REDIS_URL=redis://127.0.0.1:6379

# ── API server ─────────────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-in-production
PORT=3001

# ── Web / browser-side ─────────────────────────────────────────────────────────
# These must be reachable by the end-user's browser, so they stay as localhost
# even inside Docker (the browser isn't inside the container network).
NEXT_PUBLIC_API_URL=https://traceback-api.wildowl.tech
NEXT_PUBLIC_WS_URL=wss://traceback-api.wildowl.tech/graphql-ws
